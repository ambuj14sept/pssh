#!/usr/bin/env bash
# pssh - Persistent SSH (VS Code-like transparent session persistence)
#
# Drop-in replacement for ssh that automatically:
#   - Persists your terminal session on the server (survives connection drops)
#   - Auto-reconnects with exponential backoff when connection breaks
#   - Reattaches to your exact session state (running processes, output, etc.)
#   - Cleans up when you explicitly exit
#   - Works across multiple servers and multiple terminals simultaneously
#
# Usage:
#   pssh user@host                  # Interactive shell (like ssh)
#   pssh user@host -- ./run-api     # Run a command persistently
#   pssh list user@host             # List active sessions on server
#   pssh attach user@host <id>      # Reattach to an old session (e.g., after reboot)
#   pssh kill user@host <id>        # Kill a remote session
#   pssh kill user@host --all       # Kill all pssh sessions on server
#   pssh status                     # Show all tracked sessions across servers

set -euo pipefail

PSSH_VERSION="1.0.0"
PSSH_SESSION_DIR="${HOME}/.pssh/sessions"
PSSH_PREFIX="pssh"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# Retry configuration
INITIAL_RETRY_DELAY=1
MAX_RETRY_DELAY=30
MAX_CONSECUTIVE_FAILURES=50

# SSH keepalive configuration
SSH_SERVER_ALIVE_INTERVAL=10
SSH_SERVER_ALIVE_COUNT_MAX=3
SSH_CONNECT_TIMEOUT=10

# ─── Helpers ───────────────────────────────────────────────────────────────────

log_info()  { echo -e "${CYAN}[pssh]${NC} $*"; }
log_ok()    { echo -e "${GREEN}[pssh]${NC} $*"; }
log_warn()  { echo -e "${YELLOW}[pssh]${NC} $*"; }
log_error() { echo -e "${RED}[pssh]${NC} $*"; }

ensure_session_dir() {
    mkdir -p "$PSSH_SESSION_DIR"
}

# Generate a short unique session ID
generate_session_id() {
    local id
    id="${PSSH_PREFIX}_$(date +%s)_$$"
    echo "$id"
}

# Build SSH options array for reliable connections
build_ssh_opts() {
    local -a opts=(
        -o "ServerAliveInterval=${SSH_SERVER_ALIVE_INTERVAL}"
        -o "ServerAliveCountMax=${SSH_SERVER_ALIVE_COUNT_MAX}"
        -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}"
        -o "TCPKeepAlive=yes"
        -o "ExitOnForwardFailure=yes"
    )
    echo "${opts[@]}"
}

# Extract user@host from args (handles ssh-style arguments)
# Returns: ssh_target (user@host or host) and extra_ssh_args
parse_ssh_args() {
    local -a ssh_args=()
    local target=""
    local -a user_cmd=()
    local found_separator=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --)
                found_separator=true
                shift
                user_cmd=("$@")
                break
                ;;
            -p|-l|-i|-F|-J|-o|-L|-R|-D|-W|-w|-b|-c|-m|-O|-S|-E)
                # SSH options that take an argument
                ssh_args+=("$1" "$2")
                shift 2
                ;;
            -*)
                # SSH flags without argument
                ssh_args+=("$1")
                shift
                ;;
            *)
                if [[ -z "$target" ]]; then
                    target="$1"
                else
                    # Anything after target without -- is treated as command
                    user_cmd+=("$1")
                fi
                shift
                ;;
        esac
    done

    echo "TARGET=${target}"
    echo "SSH_ARGS=${ssh_args[*]:-}"
    echo "USER_CMD=${user_cmd[*]:-}"
}

# Track session locally for `pssh status`
track_session() {
    local session_id="$1"
    local target="$2"
    local cmd="${3:-shell}"

    ensure_session_dir
    cat > "${PSSH_SESSION_DIR}/${session_id}" <<EOF
target=${target}
command=${cmd}
started=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
pid=$$
EOF
}

untrack_session() {
    local session_id="$1"
    rm -f "${PSSH_SESSION_DIR}/${session_id}"
}

# Check if tmux is available on the remote server
check_remote_tmux() {
    local target="$1"
    shift
    local -a extra_args=("$@")

    ssh "${extra_args[@]}" \
        -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}" \
        -o BatchMode=yes \
        "$target" "command -v tmux" >/dev/null 2>&1
}

# ─── Core: Connect with persistence ───────────────────────────────────────────

do_connect() {
    local target=""
    local -a ssh_args=()
    local -a user_cmd=()

    # Parse arguments
    local found_separator=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --)
                found_separator=true
                shift
                user_cmd=("$@")
                break
                ;;
            -p|-l|-i|-F|-J|-o|-L|-R|-D|-W|-w|-b|-c|-m|-O|-S|-E)
                ssh_args+=("$1" "$2")
                shift 2
                ;;
            -*)
                ssh_args+=("$1")
                shift
                ;;
            *)
                if [[ -z "$target" ]]; then
                    target="$1"
                else
                    user_cmd+=("$1")
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$target" ]]; then
        log_error "No target specified. Usage: pssh [ssh-options] user@host [-- command]"
        exit 1
    fi

    local session_id
    session_id=$(generate_session_id)

    # Build the tmux command for the server
    local tmux_cmd
    if [[ ${#user_cmd[@]} -gt 0 ]]; then
        # Escape the command for remote shell
        local escaped_cmd
        escaped_cmd=$(printf '%q ' "${user_cmd[@]}")
        # Run command in tmux; when command exits, drop to shell so session stays
        # until user explicitly exits
        tmux_cmd="tmux new-session -A -s ${session_id} ${escaped_cmd}"
    else
        tmux_cmd="tmux new-session -A -s ${session_id}"
    fi

    # Build SSH options
    local -a ssh_connect_opts=(
        -o "ServerAliveInterval=${SSH_SERVER_ALIVE_INTERVAL}"
        -o "ServerAliveCountMax=${SSH_SERVER_ALIVE_COUNT_MAX}"
        -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}"
        -o "TCPKeepAlive=yes"
    )

    # Track this session
    track_session "$session_id" "$target" "${user_cmd[*]:-shell}"

    # Cleanup on exit
    cleanup() {
        untrack_session "$session_id"
    }
    trap cleanup EXIT

    log_info "Connecting to ${BOLD}${target}${NC} ${DIM}(session: ${session_id})${NC}"
    log_info "Session will persist through disconnects. Type ${BOLD}exit${NC} to end."
    echo ""

    # ── Reconnect loop ──
    local retry_delay=$INITIAL_RETRY_DELAY
    local failures=0
    local ever_connected=false

    while true; do
        # Attempt connection
        set +e
        ssh "${ssh_connect_opts[@]}" "${ssh_args[@]}" -t "$target" "$tmux_cmd"
        local exit_code=$?
        set -e

        # ── Decide: reconnect or stop ──

        if [[ $exit_code -eq 0 ]]; then
            # Clean exit — user typed 'exit' or command finished
            # Check if tmux session still exists (user might have detached)
            set +e
            ssh "${ssh_args[@]}" \
                -o "ConnectTimeout=5" \
                -o BatchMode=yes \
                "$target" "tmux has-session -t ${session_id} 2>/dev/null"
            local session_exists=$?
            set -e

            if [[ $session_exists -eq 0 ]]; then
                # Session still exists — user detached (Ctrl-b d), reattach
                log_info "Detached from session. Reattaching..."
                retry_delay=$INITIAL_RETRY_DELAY
                failures=0
                continue
            else
                # Session is gone — user explicitly exited
                echo ""
                log_ok "Session ended."
                break
            fi
        fi

        # Non-zero exit — connection dropped
        ever_connected=true
        failures=$((failures + 1))

        if [[ $failures -ge $MAX_CONSECUTIVE_FAILURES ]]; then
            log_error "Too many consecutive failures ($failures). Giving up."
            log_info "Your session ${BOLD}${session_id}${NC} is still running on the server."
            log_info "Reattach later with: ${BOLD}pssh attach ${target} ${session_id}${NC}"
            break
        fi

        echo ""
        log_warn "Connection lost. Reconnecting in ${retry_delay}s... ${DIM}(attempt ${failures})${NC}"
        sleep "$retry_delay"

        # Exponential backoff with cap
        retry_delay=$((retry_delay * 2))
        if [[ $retry_delay -gt $MAX_RETRY_DELAY ]]; then
            retry_delay=$MAX_RETRY_DELAY
        fi

        # Reset backoff after successful reconnect
        # (handled by continuing the loop — if ssh connects and then drops again,
        #  we'll enter here with the current backoff, but if it stays connected
        #  for a while, failures resets)
    done
}

# ─── List sessions on a remote server ─────────────────────────────────────────

do_list() {
    local target="$1"
    shift
    local -a ssh_args=("$@")

    log_info "Active sessions on ${BOLD}${target}${NC}:"
    echo ""

    local output
    set +e
    output=$(ssh "${ssh_args[@]}" \
        -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}" \
        "$target" \
        "tmux list-sessions -F '#{session_name} | created: #{session_created_string} | windows: #{session_windows} | attached: #{?session_attached,yes,no}' 2>/dev/null | grep '^${PSSH_PREFIX}_'" 2>&1)
    local rc=$?
    set -e

    if [[ $rc -ne 0 ]] || [[ -z "$output" ]]; then
        log_info "No active pssh sessions found."
        return
    fi

    echo "$output" | while IFS= read -r line; do
        local session_name
        session_name=$(echo "$line" | cut -d'|' -f1 | tr -d ' ')
        local rest
        rest=$(echo "$line" | cut -d'|' -f2-)
        echo -e "  ${GREEN}${session_name}${NC} |${rest}"
    done
    echo ""
    log_info "Reattach with: ${BOLD}pssh attach ${target} <session_name>${NC}"
}

# ─── Attach to an existing session ────────────────────────────────────────────

do_attach() {
    local target="$1"
    local session_id="$2"
    shift 2
    local -a ssh_args=("$@")

    local -a ssh_connect_opts=(
        -o "ServerAliveInterval=${SSH_SERVER_ALIVE_INTERVAL}"
        -o "ServerAliveCountMax=${SSH_SERVER_ALIVE_COUNT_MAX}"
        -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}"
        -o "TCPKeepAlive=yes"
    )

    local tmux_cmd="tmux attach-session -t ${session_id}"

    # Track locally
    track_session "$session_id" "$target" "reattached"
    cleanup() { untrack_session "$session_id"; }
    trap cleanup EXIT

    log_info "Reattaching to ${BOLD}${session_id}${NC} on ${target}..."
    echo ""

    local retry_delay=$INITIAL_RETRY_DELAY
    local failures=0

    while true; do
        set +e
        ssh "${ssh_connect_opts[@]}" "${ssh_args[@]}" -t "$target" "$tmux_cmd"
        local exit_code=$?
        set -e

        if [[ $exit_code -eq 0 ]]; then
            # Check if session still exists (detach vs exit)
            set +e
            ssh "${ssh_args[@]}" -o "ConnectTimeout=5" -o BatchMode=yes \
                "$target" "tmux has-session -t ${session_id} 2>/dev/null"
            local session_exists=$?
            set -e

            if [[ $session_exists -eq 0 ]]; then
                log_info "Detached. Reattaching..."
                retry_delay=$INITIAL_RETRY_DELAY
                failures=0
                continue
            else
                echo ""
                log_ok "Session ended."
                break
            fi
        fi

        failures=$((failures + 1))
        if [[ $failures -ge $MAX_CONSECUTIVE_FAILURES ]]; then
            log_error "Too many failures. Session may still be running on server."
            break
        fi

        echo ""
        log_warn "Connection lost. Reconnecting in ${retry_delay}s... ${DIM}(attempt ${failures})${NC}"
        sleep "$retry_delay"
        retry_delay=$((retry_delay * 2))
        [[ $retry_delay -gt $MAX_RETRY_DELAY ]] && retry_delay=$MAX_RETRY_DELAY
    done
}

# ─── Kill remote session(s) ───────────────────────────────────────────────────

do_kill() {
    local target="$1"
    local session_id="$2"
    shift 2
    local -a ssh_args=("$@")

    if [[ "$session_id" == "--all" ]]; then
        log_warn "Killing ALL pssh sessions on ${target}..."
        ssh "${ssh_args[@]}" \
            -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}" \
            "$target" \
            "tmux list-sessions -F '#{session_name}' 2>/dev/null | grep '^${PSSH_PREFIX}_' | xargs -I{} tmux kill-session -t {}" 2>/dev/null
        log_ok "Done."
    else
        log_info "Killing session ${session_id} on ${target}..."
        set +e
        ssh "${ssh_args[@]}" \
            -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}" \
            "$target" \
            "tmux kill-session -t ${session_id}" 2>/dev/null
        local rc=$?
        set -e
        if [[ $rc -eq 0 ]]; then
            log_ok "Session killed."
        else
            log_error "Session not found or already dead."
        fi
    fi
}

# ─── Show local tracking status ───────────────────────────────────────────────

do_status() {
    ensure_session_dir

    local files
    files=$(find "$PSSH_SESSION_DIR" -type f 2>/dev/null)

    if [[ -z "$files" ]]; then
        log_info "No active pssh sessions from this machine."
        return
    fi

    log_info "Sessions from this machine:"
    echo ""

    for f in $files; do
        local session_id
        session_id=$(basename "$f")
        local target cmd started pid
        target=$(grep '^target=' "$f" | cut -d= -f2-)
        cmd=$(grep '^command=' "$f" | cut -d= -f2-)
        started=$(grep '^started=' "$f" | cut -d= -f2-)
        pid=$(grep '^pid=' "$f" | cut -d= -f2-)

        # Check if local process is still running
        local status_icon
        if kill -0 "$pid" 2>/dev/null; then
            status_icon="${GREEN}●${NC}"
        else
            status_icon="${DIM}○${NC}"
            # Clean up stale tracking
            rm -f "$f"
            status_icon="${YELLOW}?${NC}"
        fi

        echo -e "  ${status_icon} ${BOLD}${session_id}${NC}"
        echo -e "    Server:  ${target}"
        echo -e "    Command: ${cmd}"
        echo -e "    Started: ${started}"
        echo ""
    done
}

# ─── Usage ─────────────────────────────────────────────────────────────────────

usage() {
    cat <<'USAGE'
pssh - Persistent SSH (VS Code-like automatic session persistence)

USAGE:
  pssh [ssh-options] user@host              Interactive persistent shell
  pssh [ssh-options] user@host -- command   Run command persistently
  pssh list [ssh-options] user@host         List active sessions on server
  pssh attach [ssh-options] user@host <id>  Reattach to a previous session
  pssh kill [ssh-options] user@host <id>    Kill a remote session
  pssh kill [ssh-options] user@host --all   Kill all sessions on server
  pssh status                               Show sessions from this machine

EXAMPLES:
  pssh deploy@prod-server                   # Persistent interactive shell
  pssh deploy@prod-server -- ./run-api      # Run a binary persistently
  pssh -p 2222 user@host                    # Custom SSH port
  pssh -i ~/.ssh/mykey user@host            # Custom SSH key
  pssh list deploy@prod-server              # See what's running
  pssh attach deploy@prod-server pssh_xxx   # Reattach after Mac reboot

BEHAVIOR:
  - Connection drops (close laptop, wifi dies) → auto-reconnects
  - Type 'exit' → session is destroyed, clean exit
  - Multiple terminals → each gets its own independent session
  - Ctrl-C → interrupts the running process (normal behavior)
  - Works with any number of servers simultaneously

REQUIREMENTS:
  - tmux must be installed on the remote server
  - Standard SSH access to the server

USAGE
}

# ─── Main ──────────────────────────────────────────────────────────────────────

main() {
    if [[ $# -eq 0 ]]; then
        usage
        exit 0
    fi

    case "$1" in
        -h|--help|help)
            usage
            exit 0
            ;;
        -v|--version)
            echo "pssh ${PSSH_VERSION}"
            exit 0
            ;;
        list)
            shift
            if [[ $# -eq 0 ]]; then
                log_error "Usage: pssh list [ssh-options] user@host"
                exit 1
            fi
            # Find the target (last non-option arg)
            local -a args=("$@")
            local target="${args[-1]}"
            unset 'args[-1]'
            do_list "$target" "${args[@]}"
            ;;
        attach)
            shift
            if [[ $# -lt 2 ]]; then
                log_error "Usage: pssh attach [ssh-options] user@host <session_id>"
                exit 1
            fi
            # Last arg is session_id, second to last is target
            local -a args=("$@")
            local session_id="${args[-1]}"
            unset 'args[-1]'
            local target="${args[-1]}"
            unset 'args[-1]'
            do_attach "$target" "$session_id" "${args[@]}"
            ;;
        kill)
            shift
            if [[ $# -lt 2 ]]; then
                log_error "Usage: pssh kill [ssh-options] user@host <session_id|--all>"
                exit 1
            fi
            local -a args=("$@")
            local session_id="${args[-1]}"
            unset 'args[-1]'
            local target="${args[-1]}"
            unset 'args[-1]'
            do_kill "$target" "$session_id" "${args[@]}"
            ;;
        status)
            do_status
            ;;
        *)
            do_connect "$@"
            ;;
    esac
}

main "$@"
